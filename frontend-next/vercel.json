{
  "name": "streamvista-media-os",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "crayonsloop.com"
        }
      ],
      "destination": "/watch"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "www.crayonsloop.com"
        }
      ],
      "destination": "/watch"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "streamvistacreator.com"
        }
      ],
      "destination": "/creator"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "www.streamvistacreator.com"
        }
      ],
      "destination": "/creator"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "streamvista.in"
        }
      ],
      "destination": "/"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "www.streamvista.in"
        }
      ],
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
