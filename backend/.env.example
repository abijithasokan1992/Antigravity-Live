# APP
APP_NAME="Crayons Pictures API"
APP_VERSION="1.0.0"
APP_ENV="development"
SECRET_KEY="REPLACE_WITH_STRONG_SECRET_64_CHARS"

# DATABASE
# For development: SQLite (zero setup)
DATABASE_URL="sqlite:///./crayons_pictures.db"
# For production: Paste your Supabase connection string here
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres"

# SUPABASE
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# CLOUDFLARE R2 (Storage - $0 egress)
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="crayons-vault"
R2_ENDPOINT_URL="https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com"

# EMAIL (Resend - 3K/mo free)
RESEND_API_KEY="re_YOUR_KEY"
EMAIL_FROM="noreply@crayonspictures.com"
EMAIL_FROM_NAME="Crayons Pictures"

# SMS (MSG91 - India DLT)
MSG91_AUTH_KEY="your-msg91-auth-key"
MSG91_SENDER_ID="CRAYON"
MSG91_TEMPLATE_ID="your-dlt-template-id"

# WHATSAPP (Meta Cloud API - 1K conv/mo free)
WHATSAPP_TOKEN="your-meta-whatsapp-token"
WHATSAPP_PHONE_ID="your-whatsapp-phone-id"

# AI (Crayons Bridge AI - already live)
GEMINI_API_KEY="your-gemini-api-key"

# PAYMENTS (Razorpay - already live)
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-secret"
